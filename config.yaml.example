# paperdigest configuration
# Generated by: paperdigest setup
# Docs: https://github.com/lysukhin/paperdigest/blob/main/docs/configuration.md

topic:
  name: "Your Research Topic"
  description: >
    Describe the kind of papers you're interested in. Be specific about
    sub-fields, methods, and applications. The LLM filter uses this to
    decide which papers are relevant to you.
  primary_keywords:
    - "keyword1"
    - "keyword2"
  secondary_keywords:
    - "related-term1"
  benchmarks: []
  arxiv_categories:
    - "cs.CV"
    - "cs.AI"

collection:
  lookback_days: 7
  max_results: 200
  blogs:
    enabled: false
    sources:
      - nvidia
      - waymo
  conferences:
    enabled: false
    years_back: 2
    venues:
      - CVPR
      - ICML

scoring:
  quality:
    w_venue: 0.25
    w_author: 0.20
    w_cite: 0.20
    w_code: 0.15
    w_fresh: 0.20
  venue_tiers:
    tier1:
      - "NeurIPS"
      - "ICML"
      - "ICLR"
      - "CVPR"
      - "ECCV"
      - "ICCV"
    tier2:
      - "IROS"
      - "ICRA"
      - "WACV"
    tier3: []

digest:
  top_n: 20
  summarize_top_n: 10
  output_dir: "data/digests"

llm:
  filter:
    enabled: true
    model: "gpt-4o-mini"
    base_url: "https://api.openai.com/v1"
    temperature:
    max_completion_tokens: 1024
    cost_control:
      max_cost_per_run: 0.10
      max_cost_per_month: 3.00
      input_cost_per_1k: 0.00005
      output_cost_per_1k: 0.0004
  summarizer:
    enabled: true
    model: "gpt-4o-mini"
    base_url: "https://api.openai.com/v1"
    temperature:
    max_completion_tokens: 16384
    max_text_chars: 50000
    language: "English"
    cost_control:
      max_cost_per_run: 0.50
      max_cost_per_month: 10.00
      input_cost_per_1k: 0.00015
      output_cost_per_1k: 0.0006

delivery:
  markdown:
    enabled: true
  telegram:
    enabled: false

database:
  path: "data/papers.db"

pwc:
  links_path: "data/pwc_links.json"

web:
  host: "0.0.0.0"
  # public_url: https://digest.example.com

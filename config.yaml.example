topic:
  name: "VLM/VLA for Autonomous Driving"
  description: >
    Papers about vision-language models (VLMs), vision-language-action models (VLAs),
    and multimodal foundation models applied to autonomous driving, including end-to-end
    driving, motion planning with language reasoning, and driving scene understanding.
    Also interested in relevant benchmarks and datasets for evaluating these systems.
  primary_keywords:
    - "autonomous driving"
    - "motion planning"
    - "driving"
    - "self-driving"
  secondary_keywords:
    - "end-to-end"
    - "vision-language model"
    - "vlm"
    - "action"
    - "vla"
    - "reasoning"
  benchmarks:
    - "nuScenes"
    - "Waymo Open"
    - "CARLA"
    - "DriveLM"
    - "OpenScene"
    - "DriveVLM"
  arxiv_categories:
    - "cs.CV"
    - "cs.AI"
    - "cs.RO"
    - "cs.LG"

collection:
  lookback_days: 3
  max_results: 200
  blogs:
    enabled: false
    sources:
      - nvidia
      - waymo
      # - wayve  # currently blocked by WAF (403)
  conferences:
    enabled: false
    years_back: 2
    venues:
      - CVPR
      - ICCV
      - ECCV
      - ICML
      - ICLR
      - AAAI
      - CoRL
      - ICRA
      - IROS
      - IV
      - ITSC
      # NeurIPS excluded — DBLP API returns 500 for this venue

enrichment:
  semantic_scholar:
    enabled: false  # set true to fetch citations/h-index (slow, 0 for fresh papers)

scoring:
  quality:
    w_venue: 0.25
    w_author: 0.20
    w_cite: 0.20
    w_code: 0.15
    w_fresh: 0.20
  venue_tiers:
    tier1:
      - "NeurIPS"
      - "ICML"
      - "ICLR"
      - "CVPR"
      - "ECCV"
      - "ICCV"
      - "AAAI"
      - "IJCAI"
      - "RSS"
      - "CoRL"
    tier2:
      - "IROS"
      - "ICRA"
      - "WACV"
      - "BMVC"
      - "ACCV"
      - "AISTATS"
      - "UAI"
    tier3:
      - "IV"
      - "ITSC"
      - "T-ITS"
      - "RA-L"
      - "T-RO"

digest:
  top_n: 10
  summarize_top_n: 10
  output_dir: "data/digests"

llm:
  filter:
    enabled: true
    model: "gpt-5-nano-2025-08-07"
    base_url: "https://api.openai.com/v1"
    temperature:
    max_completion_tokens: 1024
    extra_instructions:  # optional: appended to filter system prompt
    cost_control:
      max_cost_per_run: 0.10
      max_cost_per_month: 3.00
      input_cost_per_1k: 0.00005
      output_cost_per_1k: 0.0004
  summarizer:
    enabled: true
    model: "gpt-5-mini-2025-08-07"
    base_url: "https://api.openai.com/v1"
    temperature:
    max_completion_tokens: 16384
    max_text_chars: 50000
    language: "English"
    extra_instructions: "Include main benchmark names and key quantitative results in one_liner. In data_benchmarks, clarify whether real-world or simulated data was used."
    cost_control:
      max_cost_per_run: 0.50
      max_cost_per_month: 10.00
      input_cost_per_1k: 0.00025
      output_cost_per_1k: 0.002

delivery:
  markdown:
    enabled: true
  telegram:
    enabled: true

database:
  path: "data/papers.db"

pwc:
  links_path: "data/pwc_links.json"

web:
  # public_url: https://digest.example.com  # enables "View Full Digest" button in Telegram

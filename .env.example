# Copy this file to .env and fill in your secrets.
# Environment variables take precedence over values set here.

# OpenAI-compatible API key for LLM summarization (optional)
# LLM_API_KEY=sk-...

# Semantic Scholar API key for faster enrichment (optional, works without)
# SEMANTIC_SCHOLAR_API_KEY=

# Telegram delivery (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
